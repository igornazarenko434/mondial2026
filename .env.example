# Copy to .env and fill in. All free tiers.
#
# ⚠ CRITICAL — systemd EnvironmentFile parser does NOT strip inline `#`
#   comments. EVERY comment in this file lives on its OWN line. Do the
#   same in your .env. Lines like `KEY=value  # comment` would make
#   systemd-loaded values include the comment as part of the value — and
#   for `NEGEV_EMAIL=user@x.com  # comment` Firebase rejects with
#   INVALID_EMAIL (this exact bug bit us on 2026-06-10).
#   The startup pre-flight + `tools/audit_env.py` will refuse to proceed
#   if any line in your .env has an inline comment.

# https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_football_data_org_key

# https://the-odds-api.com (500 req/mo free)
ODDS_API_KEY=your_the_odds_api_key

# https://api-dashboard.search.brave.com  Search plan: $5/1000 + $5/mo free = 1000 free queries/mo
BRAVE_SEARCH_API_KEY=

# https://www.api-football.com (100 req/day free)
API_FOOTBALL_KEY=your_api_football_key

LOCAL_TZ=Asia/Jerusalem

# --- LLM layer (router falls back left->right) ---
# Default: free Gemini first; cheap-paid Haiku second; optional OpenAI third.
# ~400-500 small calls per tournament; expected out-of-pocket ~$0.
LLM_PROVIDER_CHAIN=gemini,claude,openai
# Models default to the small/cheap tier (see config/llm.py); override per-provider:
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4o-mini

# Gemini: FREE tier key from Google AI Studio
GEMINI_API_KEY=
# Claude: pay-as-you-go API key OR subscription Agent SDK credit (Pro/Max)
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
# OpenAI: pay-as-you-go (ChatGPT Plus does NOT grant API access)
OPENAI_API_KEY=

# --- Observability (all optional; safe defaults) ---
OBS_ENABLED=1
OBS_LOG_JSON=1
OBS_LOG_LEVEL=INFO
OBS_DB=store/obs.db
OBS_QUOTA_WARN=0.8
OTEL_SERVICE_NAME=mondial2026
# console | otlp | none
OTEL_TRACES_EXPORTER=console
# e.g. http://localhost:4318 for Jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Output delivery (where the per-game cards go) ---
# add 'telegram' for phone push
DELIVERY_CHANNELS=file,console
REPORTS_DIR=reports
# Telegram (optional, ~20 min setup, free): create a bot via @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Scheduler & watchdog ---
SCHED_POLL_SECONDS=60
SCHED_MAX_WORKERS=6
HEARTBEAT_FILE=store/heartbeat
WATCHDOG_STUCK_MIN=20
WATCHDOG_HEARTBEAT_MAX_AGE=180

# --- Win-the-pool strategy layer (default OFF — pure-EV picks) ---
# MY_PARTICIPANT must match the display name you use in the Negev Toto app.
# Used by core/scoring/standings_writer (writes YOUR row) and by
# store/repo.standings_context (looks up your row to compute leader/second
# gaps). If unset, the strategy layer no-ops even when STRATEGY_TILT > 0.
MY_PARTICIPANT=Igor
# Friends you also want to TRACK in every Telegram message (📊 standings,
# ☀️ daily summary, ⚽ kickoff card, 🃏 match cards). Comma-separated
# Negev displayNames — discover them via `tools/find_member.py <substring>`.
# Each tracked person gets the same rank/total/split/gap-to-leader audit
# block YOU get. Leave empty to render only YOUR row. Adding a friend later
# = edit this one line + `systemctl restart mondial2026`.
FRIEND_PARTICIPANTS=
# STRATEGY_TILT in [0, 1]; 0 = pure EV, 0.3–0.6 = position-aware (tilts toward
# variance when you're behind, toward safety when you're ahead). Recommended:
# keep 0 through the group stage; flip to 0.4 if you're in 4th+ after R32.
STRATEGY_TILT=0
STRATEGY_TOP_K=5
STRATEGY_SWING=6.0
# Day-9.24: per-person strategy overrides — JSON dict of {displayName: tilt}.
# Each tracked participant (you + FRIEND_PARTICIPANTS) can have a DIFFERENT
# tilt, so the same match card carries different EV-optimal picks per person
# based on THEIR standings position. Empty = everyone uses STRATEGY_TILT
# above; section is omitted (backwards-compat). Example:
#   STRATEGY_OVERRIDES={"Igor": 0.3, "Vaadia": 0.4}
# means: your picks use 0.3 tilt (slightly variance-seeking when behind),
# Vaadia's recommended picks use 0.4 (more variance-seeking).
# Each tilt is clamped to [0, 1]. Setting any override enables the
# "🎯 Per-person suggestions" block on every match card.
STRATEGY_OVERRIDES=

# --- Negev Toto connector (your friends' app; see integrations/) ---
# apiKey + projectId are PUBLIC Firebase web config and are baked into the
# connector as defaults — you normally only set your login below.
#
# AUTH — pick ONE:
#   (a) If the app supports email/password sign-in: set NEGEV_EMAIL + NEGEV_PASSWORD.
#   (b) Google-Sign-In path: leave password blank; paste a Firebase REFRESH TOKEN
#       into NEGEV_REFRESH_TOKEN (capture it from negev-toto.web.app DevTools →
#       IndexedDB → firebaseLocalStorageDb → firebaseLocalStorage → expand the
#       value → stsTokenManager.refreshToken). It auto-rotates on each refresh.
#       Re-capture if Day-9.23 startup says "refresh token expired".
NEGEV_EMAIL=
NEGEV_PASSWORD=
NEGEV_REFRESH_TOKEN=
# Default: Day-9.23 — if NEGEV_REFRESH_TOKEN is set, refresh-token auth is
# the ONLY path attempted. Failure raises with a clear remediation message.
# Set this to 1 ONLY if you want refresh-failure → silent fallback to
# email/password (NOT recommended; masks token-rotation issues).
NEGEV_ALLOW_PASSWORD_FALLBACK=0
# Tournament ID — discover via `toto_list_tournaments` (default: live Negev Toto 2026).
NEGEV_TOURNAMENT_ID=n40ykJlOIA9Mg839hz91
# Writes (preference patching + per-match prediction submission). Triple-gated:
# this env var + module check + Firestore rules. Default 0 (read-only).
NEGEV_ALLOW_WRITES=0
# Optional overrides (defaults already correct for negev-toto):
# NEGEV_API_KEY=
# NEGEV_PROJECT_ID=negev-toto
