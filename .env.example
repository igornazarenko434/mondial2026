# Copy to .env and fill in. All free tiers.
FOOTBALL_DATA_API_KEY=your_football_data_org_key      # https://www.football-data.org/client/register
ODDS_API_KEY=your_the_odds_api_key                    # https://the-odds-api.com (500 req/mo free)
API_FOOTBALL_KEY=your_api_football_key                # https://www.api-football.com (100 req/day free)
LOCAL_TZ=Asia/Jerusalem

# --- LLM layer (router falls back left->right) ---
# Default: free Gemini first; cheap-paid Haiku second; optional OpenAI third.
# ~400-500 small calls per tournament; expected out-of-pocket ~$0.
LLM_PROVIDER_CHAIN=gemini,claude,openai
# Models default to the small/cheap tier (see config/llm.py); override per-provider:
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4o-mini

# Gemini: FREE tier key from Google AI Studio
GEMINI_API_KEY=
# Claude: pay-as-you-go API key OR subscription Agent SDK credit (Pro/Max)
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
# OpenAI: pay-as-you-go (ChatGPT Plus does NOT grant API access)
OPENAI_API_KEY=

# --- Observability (all optional; safe defaults) ---
OBS_ENABLED=1
OBS_LOG_JSON=1
OBS_LOG_LEVEL=INFO
OBS_DB=store/obs.db
OBS_QUOTA_WARN=0.8
OTEL_SERVICE_NAME=mondial2026
OTEL_TRACES_EXPORTER=console            # console | otlp | none
OTEL_EXPORTER_OTLP_ENDPOINT=            # e.g. http://localhost:4318 for Jaeger

# --- Output delivery (where the per-game cards go) ---
DELIVERY_CHANNELS=file,console          # add 'telegram' for phone push
REPORTS_DIR=reports
# Telegram (optional, ~20 min setup, free): create a bot via @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Scheduler & watchdog ---
SCHED_POLL_SECONDS=60
SCHED_MAX_WORKERS=4
HEARTBEAT_FILE=store/heartbeat
WATCHDOG_STUCK_MIN=20
WATCHDOG_HEARTBEAT_MAX_AGE=180
